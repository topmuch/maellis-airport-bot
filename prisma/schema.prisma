generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ========================
// MAELLIS AIRPORT BOT - Database Schema
// ========================

// Admin users of the dashboard
model Admin {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  role      String   @default("admin")
  isActive  Boolean  @default(true)
  lastLogin DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activityLogs ActivityLog[]
}

// WhatsApp conversations
model Conversation {
  id          String   @id @default(cuid())
  userPhone   String
  userName    String?
  language    String   @default("fr")
  status      String   @default("active")
  lastMessage DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages Message[]
}

// Individual messages in a conversation
model Message {
  id             String   @id @default(cuid())
  conversationId String
  direction      String
  content        String
  messageType    String   @default("text")
  intent         String?
  entities       String?
  responseTime   Int?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

// Flight searches
model FlightSearch {
  id            String   @id @default(cuid())
  departureCode String
  arrivalCode   String
  departureCity String
  arrivalCity   String
  travelDate    String?
  passengers    Int      @default(1)
  resultsCount  Int      @default(0)
  cheapestPrice Float?
  airline       String?
  status        String   @default("completed")
  createdAt     DateTime @default(now())
}

// Flight status tracking
model FlightStatus {
  id            String   @id @default(cuid())
  flightNumber  String
  airline       String
  departureCode String
  arrivalCode   String
  scheduledDep  String?
  scheduledArr  String?
  actualDep     String?
  actualArr     String?
  gate          String?
  terminal      String?
  status        String   @default("scheduled")
  delayMinutes  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Baggage QR codes
model BaggageQR {
  id             String   @id @default(cuid())
  passengerName  String
  flightNumber   String
  pnr            String
  tagNumber      String
  weight         Float?
  destination    String
  qrToken        String   @unique
  status         String   @default("active")
  expiresAt      DateTime
  claimedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// Lounge bookings
model LoungeBooking {
  id            String   @id @default(cuid())
  passengerName String
  phone         String
  email         String?
  loungeName    String
  airportCode   String
  guests        Int      @default(1)
  bookingDate   String
  startTime     String
  durationHours Int      @default(3)
  totalPrice    Float
  paymentMethod String?
  paymentStatus String   @default("pending")
  bookingRef    String   @unique
  status        String   @default("confirmed")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Transport bookings
model TransportBooking {
  id              String   @id @default(cuid())
  passengerName   String
  phone           String
  vehicleType     String
  pickupLocation  String
  dropoffLocation String
  pickupDate      String
  pickupTime      String
  passengers      Int      @default(1)
  totalPrice      Float
  paymentMethod   String?
  paymentStatus   String   @default("pending")
  bookingRef      String   @unique
  driverName      String?
  driverPhone     String?
  vehiclePlate    String?
  status          String   @default("pending")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Payments
model Payment {
  id           String   @id @default(cuid())
  bookingId    String?
  bookingType  String
  phone        String
  provider     String
  country      String
  currency     String   @default("XOF")
  amount       Float
  status       String   @default("pending")
  externalRef  String?
  errorMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Emergency/SOS alerts
model EmergencyAlert {
  id          String   @id @default(cuid())
  userPhone   String
  userName    String?
  alertType   String
  location    String?
  description String
  severity    String   @default("medium")
  status      String   @default("open")
  assignedTo  String?
  resolution  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Activity logs
model ActivityLog {
  id        String   @id @default(cuid())
  adminId   String?
  action    String
  module    String
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  admin Admin? @relation(fields: [adminId], references: [id])
}

// System settings
model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  type        String   @default("string")
  group       String   @default("general")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
