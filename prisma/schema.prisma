generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Account {
  id                String   @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  AuthUser          AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model ActivityLog {
  id        String   @id
  adminId   String?
  action    String
  module    String
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
  Admin     Admin?   @relation(fields: [adminId], references: [id])
}

model AdCampaign {
  id            String          @id
  airportCode   String
  name          String
  description   String?
  startDate     DateTime
  endDate       DateTime
  totalBudget   Float
  spentBudget   Float           @default(0)
  status        String          @default("draft")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime
  Advertisement Advertisement[]

  @@index([airportCode, status])
}

model AdClick {
  id              String       @id
  impressionId    String
  converted       Boolean      @default(false)
  conversionValue Float        @default(0)
  timestamp       DateTime     @default(now())
  AdImpression    AdImpression @relation(fields: [impressionId], references: [id], onDelete: Cascade)

  @@index([impressionId])
}

model AdImpression {
  id              String        @id
  advertisementId String
  sessionId       String?
  placement       String
  deviceInfo      String?
  location        String?
  timestamp       DateTime      @default(now())
  AdClick         AdClick[]
  Advertisement   Advertisement @relation(fields: [advertisementId], references: [id], onDelete: Cascade)

  @@index([advertisementId, timestamp])
}

model Admin {
  id           String        @id
  name         String
  email        String        @unique
  role         String        @default("admin")
  passwordHash String
  airportCode  String?
  refreshToken String?
  isActive     Boolean       @default(true)
  lastLogin    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime
  ActivityLog  ActivityLog[]
}

model Advertisement {
  id              String         @id
  airportCode     String
  campaignId      String?
  merchantId      String?
  title           String
  description     String?
  type            String
  placement       String
  imageUrl        String
  videoUrl        String?
  targetUrl       String?
  ctaText         String         @default("En savoir plus")
  targetAudience  String?
  startDate       DateTime
  endDate         DateTime
  budget          Float
  budgetType      String         @default("total")
  cpmRate         Float?
  cpcRate         Float?
  impressions     Int            @default(0)
  clicks          Int            @default(0)
  conversions     Int            @default(0)
  revenue         Float          @default(0)
  status          String         @default("draft")
  rejectionReason String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime
  AdImpression    AdImpression[]
  Merchant        Merchant?      @relation(fields: [merchantId], references: [id])
  AdCampaign      AdCampaign?    @relation(fields: [campaignId], references: [id])

  @@index([type, placement])
  @@index([airportCode, status, startDate, endDate])
}

model AudioGeneration {
  id           String   @id
  phone        String?
  userId       String?
  type         String
  inputText    String
  audioUrl     String?
  language     String   @default("fr")
  provider     String   @default("mock")
  durationSec  Int      @default(0)
  status       String   @default("pending")
  errorMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime

  @@index([status])
  @@index([type])
  @@index([phone, createdAt])
}

model AuthUser {
  id                                        String       @id
  name                                      String?
  email                                     String       @unique
  emailVerified                             DateTime?
  image                                     String?
  password                                  String?
  role                                      String       @default("AGENT")
  airportCode                               String?
  isActive                                  Boolean      @default(true)
  createdAt                                 DateTime     @default(now())
  updatedAt                                 DateTime
  Account                                   Account[]
  Invitation_Invitation_usedByToAuthUser    Invitation?  @relation("Invitation_usedByToAuthUser")
  Invitation_Invitation_invitedByToAuthUser Invitation[] @relation("Invitation_invitedByToAuthUser")
  Session                                   Session[]
}

model BaggageClaim {
  id            String    @id
  baggageId     String?
  phone         String
  passengerName String
  description   String
  flightNumber  String?
  location      String?
  status        String    @default("open")
  resolution    String?
  compensation  Float?
  resolvedAt    DateTime?
  assignedTo    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime

  @@index([phone])
  @@index([status, createdAt])
}

model BaggageQR {
  id            String    @id
  userId        String?
  passengerName String
  phone         String
  flightNumber  String
  pnr           String
  tagNumber     String
  weight        Float?
  destination   String
  qrToken       String    @unique
  status        String    @default("active")
  lastScan      DateTime?
  expiresAt     DateTime
  createdAt     DateTime  @default(now())
  updatedAt     DateTime
}

model BillingClient {
  id        String    @id
  name      String
  email     String    @unique
  phone     String
  company   String?
  taxId     String?
  address   String
  currency  String    @default("XOF")
  taxRate   Float     @default(0.18)
  isActive  Boolean   @default(true)
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime
  Invoice   Invoice[]

  @@index([isActive, createdAt])
}

model BillingSettings {
  id              String   @id @default("global")
  nextInvoiceNum  Int      @default(1)
  defaultTaxRate  Float    @default(0.18)
  gracePeriodDays Int      @default(3)
  reminderDays    String   @default("[3,7,15]")
  legalName       String   @default("MAELLIS Technologies")
  legalAddress    String   @default("Dakar, Sénégal")
  legalTaxId      String   @default("")
  legalRccm       String   @default("")
  bankName        String   @default("")
  bankAccount     String   @default("")
  paymentLink     String   @default("")
  updatedAt       DateTime
}

model Cart {
  id            String     @id
  customerPhone String     @unique
  updatedAt     DateTime
  createdAt     DateTime   @default(now())
  CartItem      CartItem[]
}

model CartItem {
  id              String   @id
  cartId          String
  productId       String
  productName     String
  productImage    String?
  merchantId      String
  merchantName    String
  quantity        Int      @default(1)
  unitPrice       Float
  discountPercent Float    @default(0)
  addedAt         DateTime @default(now())
  Cart            Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@index([cartId])
}

model CheckInSession {
  id              String   @id
  phone           String
  passengerName   String?
  flightNumber    String
  airline         String?
  pnr             String?
  departureCode   String?
  arrivalCode     String?
  flightDate      String?
  checkInUrl      String?
  boardingPassUrl String?
  seat            String?
  gate            String?
  terminal        String?
  status          String   @default("detected")
  errorMessage    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime

  @@index([status])
  @@index([pnr])
  @@index([flightNumber])
  @@index([phone, createdAt])
}

model CheckinAirline {
  id           String   @id
  iataCode     String   @unique
  airlineName  String
  checkinUrl   String
  apiUrl       String?
  notes        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime
}

model Conversation {
  id                  String                @id
  userId              String
  messages            String
  intent              String?
  resolved            Boolean               @default(false)
  language            String                @default("fr")
  status              String                @default("active")
  lastMessage         DateTime              @default(now())
  createdAt           DateTime              @default(now())
  updatedAt           DateTime
  User                User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  ConversationMessage ConversationMessage[]
}

model ConversationMessage {
  id             String       @id
  conversationId String
  role           String
  content        String
  intent         String?
  entities       String?
  language       String?
  metadata       String?
  createdAt      DateTime     @default(now())
  Conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([intent, createdAt])
  @@index([conversationId, createdAt])
}

model CrisisAlert {
  id             String    @id
  airportCode    String    @default("DSS")
  title          String
  description    String
  severity       String    @default("medium")
  status         String    @default("draft")
  targetType     String    @default("all")
  targetValue    String?
  message        String
  sentCount      Int       @default(0)
  deliveredCount Int       @default(0)
  failedCount    Int       @default(0)
  optOutCount    Int       @default(0)
  createdBy      String?
  activatedAt    DateTime?
  closedAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime

  @@index([severity, status])
  @@index([airportCode, status])
}

model DayUseBooking {
  id                 String    @id
  hotelId            String
  roomId             String
  roomType           String    @default("standard")
  passengerName      String
  phone              String
  email              String?
  flightNumber       String?
  bookingDate        String
  startTime          String
  durationHours      Int       @default(4)
  guests             Int       @default(1)
  unitPrice          Float
  totalPrice         Float
  currency           String    @default("XOF")
  paymentMethod      String?
  paymentStatus      String    @default("pending")
  bookingRef         String    @unique
  qrCheckin          String?
  status             String    @default("confirmed")
  cancellationReason String?
  cancelledAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime
  Hotel              Hotel     @relation(fields: [hotelId], references: [id])

  @@index([status])
  @@index([phone])
  @@index([hotelId, bookingDate])
}

model DocumentChunk {
  id             String        @id
  kbId           String
  content        String
  chunkIndex     Int
  tokenCount     Int           @default(0)
  embedding      String?
  embeddingModel String?
  metadata       String        @default("{}")
  KnowledgeBase  KnowledgeBase @relation(fields: [kbId], references: [id], onDelete: Cascade)

  @@index([kbId])
}

model EmergencyAlert {
  id          String   @id
  airportCode String   @default("DSS")
  userPhone   String
  userEmail   String?
  userName    String?
  alertType   String
  location    String?
  description String
  severity    String   @default("medium")
  status      String   @default("open")
  assignedTo  String?
  resolution  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime

  @@index([severity, status])
  @@index([airportCode, status, createdAt])
}

model EmergencyContact {
  id          String   @id
  airportCode String
  category    String
  name        String
  phoneNumber String
  whatsappNum String?
  email       String?
  isPrimary   Boolean  @default(false)
  isActive    Boolean  @default(true)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime

  @@index([airportCode, isActive])
  @@index([airportCode, category])
}

model FAQ {
  id            String         @id
  airportCode   String         @default("DSS")
  category      String
  question      String
  answer        String
  keywords      String         @default("[]")
  priority      Int            @default(0)
  isActive      Boolean        @default(true)
  viewCount     Int            @default(0)
  resolvedCount Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime
  FAQAnalytics  FAQAnalytics[]

  @@index([airportCode, category, isActive])
}

model FAQAnalytics {
  id           String   @id
  airportCode  String   @default("DSS")
  faqId        String?
  userQuestion String
  matchedFAQ   Boolean
  language     String   @default("fr")
  score        Float?
  timestamp    DateTime @default(now())
  FAQ          FAQ?     @relation(fields: [faqId], references: [id])

  @@index([matchedFAQ, timestamp])
  @@index([airportCode, timestamp])
}

model FAQSuggestion {
  id             String   @id
  airportCode    String   @default("DSS")
  question       String
  proposedAnswer String?
  category       String?
  status         String   @default("pending")
  suggestedBy    String   @default("user")
  createdAt      DateTime @default(now())

  @@index([airportCode, status])
}

model Feedback {
  id           String   @id
  phone        String
  userName     String?
  flightNumber String?
  airportCode  String   @default("DSS")
  rating       Int
  category     String   @default("general")
  comment      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime

  @@index([rating])
  @@index([airportCode, createdAt])
}

model FlightNotification {
  id            String   @id
  flightNumber  String
  airline       String?
  type          String
  message       String
  priority      String   @default("medium")
  departureCode String?
  arrivalCode   String?
  isRead        Boolean  @default(false)
  isDismissed   Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([priority, createdAt])
  @@index([flightNumber, isRead])
}

model FlightSearch {
  id            String   @id
  userId        String?
  departureCode String
  arrivalCode   String
  departureCity String
  arrivalCity   String
  travelDate    String?
  passengers    Int      @default(1)
  results       String?
  cheapestPrice Float?
  airline       String?
  status        String   @default("completed")
  createdAt     DateTime @default(now())
}

model FlightStatus {
  id            String   @id
  flightNumber  String
  airline       String
  departureCode String
  arrivalCode   String
  scheduledDep  String?
  scheduledArr  String?
  actualDep     String?
  actualArr     String?
  gate          String?
  terminal      String?
  status        String   @default("scheduled")
  delayMinutes  Int      @default(0)
  aircraft      String?
  estimatedDep  String?
  estimatedArr  String?
  departureCity String?
  arrivalCity   String?
  aircraftType  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime
}

model FlightSubscription {
  id           String   @id
  flightNumber String
  phone        String
  events       String   @default("delay,gate_change,cancellation")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime

  @@index([flightNumber, isActive])
}

model Hotel {
  id            String          @id
  airportCode   String          @default("DSS")
  name          String
  description   String?
  starRating    Int             @default(3)
  address       String
  distanceKm    Float           @default(0)
  terminal      String          @default("")
  imageUrl      String?
  contactPhone  String          @default("")
  contactEmail  String          @default("")
  isActive      Boolean         @default(true)
  amenities     String          @default("[]")
  checkInTime   String          @default("14:00")
  checkOutTime  String          @default("12:00")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime
  DayUseBooking DayUseBooking[]
  HotelRoom     HotelRoom[]

  @@unique([airportCode, name])
  @@index([airportCode, isActive])
}

model HotelRoom {
  id             String   @id
  hotelId        String
  roomType       String
  name           String
  description    String?
  maxGuests      Int      @default(2)
  basePrice      Float
  hourPrice      Float    @default(0)
  minHours       Int      @default(3)
  maxHours       Int      @default(8)
  currency       String   @default("XOF")
  totalRooms     Int      @default(10)
  availableRooms Int      @default(10)
  amenities      String   @default("[]")
  imageUrl       String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime
  Hotel          Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@index([hotelId, isActive])
}

model Invitation {
  id                                      String    @id
  email                                   String    @unique
  token                                   String    @unique
  role                                    String    @default("AGENT")
  airportCode                             String?
  invitedBy                               String?
  usedBy                                  String?   @unique
  usedAt                                  DateTime?
  expiresAt                               DateTime
  createdAt                               DateTime  @default(now())
  AuthUser_Invitation_usedByToAuthUser    AuthUser? @relation("Invitation_usedByToAuthUser", fields: [usedBy], references: [id])
  AuthUser_Invitation_invitedByToAuthUser AuthUser? @relation("Invitation_invitedByToAuthUser", fields: [invitedBy], references: [id])
}

model Invoice {
  id              String            @id
  invoiceNumber   String            @unique
  clientId        String
  type            String
  status          String            @default("draft")
  issueDate       DateTime          @default(now())
  dueDate         DateTime
  paidAt          DateTime?
  currency        String            @default("XOF")
  subtotal        Float
  taxRate         Float
  taxAmount       Float
  total           Float
  pdfUrl          String?
  receiptUrl      String?
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  BillingClient   BillingClient     @relation(fields: [clientId], references: [id])
  InvoiceItem     InvoiceItem[]
  InvoicePayment  InvoicePayment[]
  InvoiceReminder InvoiceReminder[]

  @@index([status, type])
  @@index([dueDate, status])
  @@index([clientId, status, issueDate])
}

model InvoiceItem {
  id          String  @id
  invoiceId   String
  description String
  quantity    Int     @default(1)
  unitPrice   Float
  total       Float
  Invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model InvoicePayment {
  id            String   @id
  invoiceId     String
  amount        Float
  method        String
  transactionId String?  @unique
  status        String   @default("pending")
  paidAt        DateTime @default(now())
  metadata      String   @default("{}")
  Invoice       Invoice  @relation(fields: [invoiceId], references: [id])

  @@index([transactionId])
  @@index([invoiceId])
}

model InvoiceReminder {
  id          String   @id
  invoiceId   String
  type        String
  sentAt      DateTime @default(now())
  daysOverdue Int
  status      String   @default("sent")
  metadata    String   @default("{}")
  Invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([type, sentAt])
  @@index([invoiceId, sentAt])
}

model KnowledgeBase {
  id            String          @id
  airportCode   String          @default("DSS")
  title         String
  fileName      String
  fileType      String
  fileSize      Int             @default(0)
  fileUrl       String?
  content       String?
  chunkCount    Int             @default(0)
  isActive      Boolean         @default(true)
  status        String          @default("pending")
  errorMessage  String?
  uploadedBy    String
  processedAt   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime
  DocumentChunk DocumentChunk[]

  @@index([status])
  @@index([airportCode, isActive])
}

model Lounge {
  id               String          @id
  airportCode      String
  name             String
  description      String?
  terminal         String          @default("")
  gateLocation     String          @default("")
  location         String          @default("")
  imageUrl         String?
  priceStandard    Float           @default(0)
  priceBusiness    Float           @default(0)
  priceFirstClass  Float           @default(0)
  priceChild       Float           @default(0)
  currency         String          @default("XOF")
  maxCapacity      Int             @default(50)
  currentOccupancy Int             @default(0)
  isOpen           Boolean         @default(true)
  openingTime      String          @default("06:00")
  closingTime      String          @default("22:00")
  openingHours     String          @default("\"06:00-22:00\"")
  amenities        String          @default("[]")
  accessLevel      String          @default("all")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime
  LoungeBooking    LoungeBooking[]

  @@unique([airportCode, name])
  @@index([airportCode, isOpen])
}

model LoungeBooking {
  id            String   @id
  loungeId      String?
  passengerName String
  phone         String
  email         String?
  loungeName    String   @default("")
  airportCode   String
  guests        Int      @default(1)
  bookingDate   String
  startTime     String
  durationHours Int      @default(3)
  ticketClass   String   @default("standard")
  flightNumber  String?
  unitPrice     Float    @default(0)
  totalPrice    Float
  paymentMethod String?
  paymentStatus String   @default("pending")
  bookingRef    String   @unique
  status        String   @default("confirmed")
  createdAt     DateTime @default(now())
  updatedAt     DateTime
  Lounge        Lounge?  @relation(fields: [loungeId], references: [id])

  @@index([status])
  @@index([loungeId, bookingDate])
}

model Merchant {
  id              String           @id
  airportCode     String
  name            String
  description     String?
  logo            String?
  category        String
  terminal        String           @default("")
  gate            String?
  location        String?
  phone           String
  email           String
  openingHours    String           @default("{}")
  isActive        Boolean          @default(true)
  isVerified      Boolean          @default(false)
  commissionRate  Float            @default(0.10)
  paymentSchedule String           @default("weekly")
  totalSales      Float            @default(0)
  totalOrders     Int              @default(0)
  averageRating   Float            @default(0)
  reviewsCount    Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime
  Advertisement   Advertisement[]
  MerchantPayout  MerchantPayout[]
  Order           Order[]
  Product         Product[]
  Review          Review[]

  @@unique([airportCode, name])
  @@index([airportCode, category, isActive])
}

model MerchantPayout {
  id               String    @id
  merchantId       String
  orderId          String
  orderTotal       Float
  commissionRate   Float
  commissionAmount Float
  currency         String    @default("XOF")
  status           String    @default("pending")
  paidAt           DateTime?
  paidBy           String?
  reference        String?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime
  Merchant         Merchant  @relation(fields: [merchantId], references: [id])

  @@index([status])
  @@index([merchantId, status])
}

model Message {
  id             String   @id
  conversationId String
  direction      String
  content        String
  messageType    String   @default("text")
  intent         String?
  entities       String?
  responseTime   Int?
  createdAt      DateTime @default(now())
}

model MilesTransaction {
  id            String     @id
  walletId      String
  type          String
  amount        Int
  reason        String
  description   String?
  referenceType String?
  referenceId   String?
  createdAt     DateTime   @default(now())
  UserWallet    UserWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([type, createdAt])
  @@index([walletId, createdAt])
}

model MusicCategory {
  id          String       @id
  name        String
  slug        String       @unique
  description String?
  icon        String       @default("🎵")
  color       String       @default("#F97316")
  imageUrl    String?
  sortOrder   Int          @default(0)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime
  MusicTrack  MusicTrack[]

  @@index([isActive])
  @@index([sortOrder])
}

model MusicTrack {
  id            String        @id
  categoryId    String
  title         String
  artist        String        @default("")
  youtubeUrl    String
  youtubeId     String        @unique
  thumbnailUrl  String
  duration      String?
  sortOrder     Int           @default(0)
  isActive      Boolean       @default(true)
  playCount     Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime
  MusicCategory MusicCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([playCount, createdAt])
  @@index([isActive])
  @@index([categoryId, sortOrder])
}

model Order {
  id                 String      @id
  orderNumber        String      @unique
  merchantId         String
  airportCode        String
  customerName       String
  customerPhone      String
  customerEmail      String?
  flightNumber       String?
  gate               String?
  type               String      @default("pickup")
  status             String      @default("pending")
  subtotal           Float       @default(0)
  tax                Float       @default(0)
  deliveryFee        Float       @default(0)
  total              Float       @default(0)
  currency           String      @default("XOF")
  paymentMethod      String?
  paymentStatus      String      @default("pending")
  transactionId      String?
  scheduledTime      DateTime?
  notes              String?
  qrCode             String?
  completedAt        DateTime?
  cancelledAt        DateTime?
  cancellationReason String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime
  Merchant           Merchant    @relation(fields: [merchantId], references: [id])
  OrderItem          OrderItem[]

  @@index([customerPhone, status])
  @@index([orderNumber])
  @@index([merchantId, status])
}

model OrderItem {
  id             String  @id
  orderId        String
  productId      String
  productName    String
  productImage   String?
  quantity       Int
  unitPrice      Float
  discount       Float   @default(0)
  total          Float
  customizations String?
  Order          Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Partner {
  id             String        @id
  airportCode    String
  type           String
  name           String
  logoUrl        String?
  email          String        @unique
  phone          String
  contactPerson  String
  commissionRate Float         @default(0.10)
  contractStart  DateTime      @default(now())
  contractEnd    DateTime?
  status         String        @default("pending")
  isActive       Boolean       @default(false)
  inviteToken    String?
  activatedAt    DateTime?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime
  PartnerUser    PartnerUser[]
  Pharmacy       Pharmacy?

  @@unique([airportCode, name])
  @@index([airportCode, type, isActive])
}

model PartnerUser {
  id        String    @id
  partnerId String
  email     String    @unique
  name      String
  password  String
  phone     String    @default("")
  role      String    @default("agent")
  isActive  Boolean   @default(true)
  lastLogin DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime
  Partner   Partner   @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId])
}

model Pharmacy {
  id            String         @id
  partnerId     String         @unique
  airportCode   String         @default("DSS")
  name          String
  address       String         @default("")
  terminal      String         @default("")
  contactPhone  String         @default("")
  contactEmail  String         @default("")
  openingHours  String         @default("{}")
  deliveryZones String         @default("[]")
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime
  Partner       Partner        @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  PharmacyOrder PharmacyOrder[]

  @@index([airportCode, isActive])
}

model Payment {
  id           String   @id
  bookingId    String?
  bookingType  String
  phone        String
  provider     String
  country      String
  currency     String   @default("XOF")
  amount       Float
  status       String   @default("pending")
  externalRef  String?
  errorMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime
}

model PharmacyOrder {
  id               String   @id
  airportCode      String   @default("DSS")
  customerName     String
  customerPhone    String
  flightNumber     String?
  gate             String?
  urgency          String   @default("normal")
  items            String
  subtotal         Float    @default(0)
  deliveryFee      Float    @default(0)
  total            Float    @default(0)
  currency         String   @default("XOF")
  paymentMethod    String?
  paymentStatus    String   @default("pending")
  paymentRef       String?
  pharmacyId       String?
  pharmacyName     String?
  status           String   @default("pending")
  deliveryNotes    String?
  estimatedMinutes Int      @default(15)
  orderRef         String   @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime
  Pharmacy         Pharmacy? @relation(fields: [pharmacyId], references: [id])

  @@index([airportCode])
  @@index([status])
  @@index([customerPhone, status])
}

model ProactiveLog {
  id             String    @id
  phone          String
  flightNumber   String?
  airportCode    String    @default("DSS")
  messageType    String
  messageContent String
  triggeredBy    String
  status         String    @default("sent")
  sentAt         DateTime  @default(now())
  deliveredAt    DateTime?
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  @@index([airportCode, messageType])
  @@index([phone, sentAt])
}

model Product {
  id              String   @id
  merchantId      String
  name            String
  description     String?
  category        String
  price           Float
  currency        String   @default("XOF")
  images          String   @default("[]")
  stock           Int      @default(0)
  isAvailable     Boolean  @default(true)
  isPreOrder      Boolean  @default(false)
  tags            String   @default("[]")
  discountPercent Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime
  Merchant        Merchant @relation(fields: [merchantId], references: [id])

  @@index([category])
  @@index([merchantId, isAvailable])
}

model RebookingLog {
  id               String   @id
  phone            String
  passengerName    String?
  originalFlight   String
  originalAirline  String?
  originalDepCode  String?
  originalArrCode  String?
  suggestedFlight  String?
  suggestedAirline String?
  suggestedDepTime String?
  suggestedPrice   Float?
  currency         String   @default("XOF")
  status           String   @default("sent")
  response         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime

  @@index([status])
  @@index([originalFlight])
  @@index([phone, createdAt])
}

model Review {
  id            String    @id
  merchantId    String
  customerName  String
  customerPhone String
  orderId       String?
  rating        Int
  comment       String?
  images        String    @default("[]")
  isVerified    Boolean   @default(true)
  response      String?
  respondedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime
  Merchant      Merchant  @relation(fields: [merchantId], references: [id])

  @@index([merchantId, rating])
}

model Reward {
  id          String     @id
  walletId    String
  name        String
  description String?
  costPoints  Int
  type        String
  value       String?
  status      String     @default("available")
  redeemedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime
  UserWallet  UserWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([type])
  @@index([walletId, status])
}

model Session {
  id           String   @id
  sessionToken String   @unique
  userId       String
  expires      DateTime
  AuthUser     AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Setting {
  id          String   @id
  key         String   @unique
  value       String
  type        String   @default("string")
  group       String   @default("general")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime
}

model Ticket {
  id            String    @id
  phone         String
  passengerName String
  type          String
  priority      String    @default("normal")
  status        String    @default("open")
  description   String
  flightNumber  String?
  gate          String?
  category      String?
  resolution    String?
  assignedTo    String?
  slaDeadline   DateTime?
  resolvedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime

  @@index([type])
  @@index([phone])
  @@index([status, priority])
}

model TicketScan {
  id            String    @id
  phone         String
  passengerName String?
  pnr           String?
  flightNumber  String?
  airline       String?
  departureCode String?
  arrivalCode   String?
  departureCity String?
  arrivalCity   String?
  flightDate    String?
  seat          String?
  boardingTime  String?
  gate          String?
  terminal      String?
  class         String?
  rawText       String?
  confidence    Float     @default(0)
  provider      String    @default("mock")
  status        String    @default("pending")
  confirmedAt   DateTime?
  rejectedAt    DateTime?
  source        String    @default("whatsapp")
  imageUrl      String?
  metadata      String    @default("{}")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime

  @@index([status])
  @@index([flightNumber])
  @@index([pnr])
  @@index([phone, createdAt])
}

model TransportBooking {
  id                String             @id
  providerId        String?
  passengerName     String
  phone             String
  email             String?
  vehicleType       String             @default("")
  pickupLocation    String
  dropoffLocation   String
  pickupDate        String
  pickupTime        String
  passengers        Int                @default(1)
  totalPrice        Float              @default(0)
  paymentMethod     String?
  paymentStatus     String             @default("pending")
  bookingRef        String             @unique
  driverName        String?
  driverPhone       String?
  vehiclePlate      String?
  distanceKm        Float?
  estimatedPrice    Float?
  finalPrice        Float?
  status            String             @default("pending")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime
  TransportProvider TransportProvider? @relation(fields: [providerId], references: [id])

  @@index([providerId, status])
}

model TransportProvider {
  id               String             @id
  airportCode      String
  name             String
  type             String
  logoUrl          String?
  isActive         Boolean            @default(true)
  baseFare         Float              @default(0)
  perKmRate        Float              @default(0)
  minFare          Float              @default(0)
  nightSurcharge   Float              @default(0)
  contactPhone     String             @default("")
  contactEmail     String             @default("")
  whatsappNumber   String             @default("")
  contacts         String?
  serviceZones     String             @default("[]")
  createdAt        DateTime           @default(now())
  updatedAt        DateTime
  TransportBooking TransportBooking[]

  @@unique([airportCode, name])
  @@index([airportCode, type, isActive])
}

model User {
  id           String         @id
  phone        String         @unique
  name         String?
  language     String         @default("fr")
  isActive     Boolean        @default(true)
  preferences  String         @default("{}")
  lastSeen     DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime
  Conversation Conversation[]
  UserWallet   UserWallet?
}

model UserWallet {
  id               String             @id
  userId           String             @unique
  phone            String             @unique
  balance          Int                @default(0)
  tier             String             @default("bronze")
  totalEarned      Int                @default(0)
  totalSpent       Int                @default(0)
  streakDays       Int                @default(0)
  lastActivityAt   DateTime?
  tierUpdatedAt    DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime
  MilesTransaction MilesTransaction[]
  Reward           Reward[]
  User             User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([balance])
  @@index([tier])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PointRule {
  id          String   @id
  action      String   @unique
  label       String
  points      Int
  description String?
  isActive    Boolean  @default(true)
  maxDaily    Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime
}

model WiFiVoucher {
  id              String    @id
  airportCode     String    @default("DSS")
  voucherCode     String    @unique
  phone           String?
  planType        String    @default("free")
  durationMinutes Int       @default(60)
  bandwidthMbps   Int       @default(10)
  price           Float     @default(0)
  currency        String    @default("XOF")
  paymentStatus   String    @default("none")
  portalUrl       String?
  isActive        Boolean   @default(true)
  activatedAt     DateTime?
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime

  @@index([airportCode, isActive])
  @@index([phone])
  @@index([voucherCode])
}

model Wishlist {
  id            String   @id
  customerPhone String
  productId     String
  createdAt     DateTime @default(now())

  @@unique([customerPhone, productId])
  @@index([customerPhone])
}

// ═══════════════════════════════════════════════════════════════════════════
// NEW MODELS — Smartly Advanced Modules (Phase 2)
// ═══════════════════════════════════════════════════════════════════════════

/// Pharmacy store linked to a Partner account
model Pharmacy {
  id             String   @id
  partnerId      String   @unique
  airportCode    String   @default("DSS")
  name           String
  address        String   @default("")
  terminal       String   @default("")
  contactPhone   String   @default("")
  contactEmail   String   @default("")
  logoUrl        String?
  openingHours   String   @default("{}")
  deliveryZones  String   @default("[]")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime
  Partner        Partner  @relation(fields: [partnerId], references: [id])
  PharmacyOrder  PharmacyOrder[]

  @@index([airportCode, isActive])
}

/// Airline check-in URL database (IATA code → check-in link)
model CheckinAirline {
  id          String   @id
  iataCode    String   @unique
  airlineName String
  checkinUrl  String
  apiUrl      String?
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime

  @@index([iataCode])
}

/// Gamification point rules configuration
model PointRule {
  id          String   @id
  action      String   @unique
  label       String
  points      Int
  description String?
  isActive    Boolean  @default(true)
  maxDaily    Int?     /// Max times this rule can trigger per user per day (null = unlimited)
  createdAt   DateTime @default(now())
  updatedAt   DateTime
}
