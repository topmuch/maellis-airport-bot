# =============================================================================
# MAELLIS Airport Bot — Environment Configuration
# =============================================================================
# Copy this file to `.env` and fill in the values.
# Never commit your `.env` file to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL=file:/home/z/my-project/db/custom.db

# ---------------------------------------------------------------------------
# Email Configuration
# ---------------------------------------------------------------------------
# Transport type: smtp (real SMTP server) | console (dev mode, logs to stdout)
EMAIL_TRANSPORT=console

# SMTP settings (only used when EMAIL_TRANSPORT=smtp)
EMAIL_HOST=smtp.mailtrap.io          # or smtp.gmail.com, etc.
EMAIL_PORT=587
EMAIL_USER=your_smtp_user
EMAIL_PASS=your_smtp_password
EMAIL_FROM=noreply@maellis.aero
EMAIL_FROM_NAME=MAELLIS Airport Bot

# Legacy SMTP vars (still supported for backward compatibility)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=

# ---------------------------------------------------------------------------
# Authentication (NextAuth / JWT)
# ---------------------------------------------------------------------------
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000
JWT_SECRET=your_jwt_secret_here

# ---------------------------------------------------------------------------
# Aviation API (Flight tracking)
# ---------------------------------------------------------------------------
AVIATION_API_KEY=your_aviationstack_key

# ---------------------------------------------------------------------------
# AI / LLM
# ---------------------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key

# ---------------------------------------------------------------------------
# WhatsApp Business API
# ---------------------------------------------------------------------------
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# ---------------------------------------------------------------------------
# Payment (CinetPay)
# ---------------------------------------------------------------------------
CINETPAY_API_KEY=
CINETPAY_SITE_ID=

# ---------------------------------------------------------------------------
# Socket.io (WebSocket service)
# ---------------------------------------------------------------------------
WS_PORT=3003
