# =============================================================================
# MAELLIS Airport Bot — Environment Configuration Template
# =============================================================================
# Copy this file to `.env` and fill in the values.
# NEVER commit your `.env` file to version control.
# Generate secrets with: openssl rand -base64 32
# =============================================================================

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL=file:./dev.db

# ---------------------------------------------------------------------------
# Email Configuration
# ---------------------------------------------------------------------------
EMAIL_TRANSPORT=console
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=your_smtp_user
EMAIL_PASS=your_smtp_password
EMAIL_FROM=noreply@example.com
EMAIL_FROM_NAME=Smartly Assistant

# ---------------------------------------------------------------------------
# Authentication (REQUIRED for production)
# ---------------------------------------------------------------------------
NEXTAUTH_SECRET=change_me_generate_with_openssl_rand_base64_32
AUTH_SECRET=change_me_generate_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000
JWT_SECRET=change_me_generate_with_openssl_rand_base64_32

# ---------------------------------------------------------------------------
# Aviation API (Flight tracking)
# ---------------------------------------------------------------------------
AVIATION_API_KEY=your_aviationstack_key

# ---------------------------------------------------------------------------
# AI / LLM
# ---------------------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key

# ---------------------------------------------------------------------------
# WhatsApp Business API
# ---------------------------------------------------------------------------
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# ---------------------------------------------------------------------------
# Payment (CinetPay)
# ---------------------------------------------------------------------------
CINETPAY_API_KEY=
CINETPAY_SITE_ID=

# ---------------------------------------------------------------------------
# Socket.io (WebSocket service)
# ---------------------------------------------------------------------------
WS_PORT=3003
