# =============================================================================
# MAELLIS Airport Bot — Environment Configuration Template
# =============================================================================
# Copy this file to `.env` and fill in the values.
# NEVER commit your `.env` file to version control.
# Generate secrets with: openssl rand -base64 32
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://smartly.aero
NODE_ENV=production

# ---------------------------------------------------------------------------
# Database (SQLite — use file: for production persistence)
# ---------------------------------------------------------------------------
DATABASE_URL=file:./prod.db

# ---------------------------------------------------------------------------
# Email Configuration
# ---------------------------------------------------------------------------
EMAIL_TRANSPORT=smtp
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=your_smtp_user
EMAIL_PASS=your_smtp_password
EMAIL_FROM=noreply@smartly.aero
EMAIL_FROM_NAME=Smartly Assistant

# ---------------------------------------------------------------------------
# Authentication (REQUIRED for production)
# ---------------------------------------------------------------------------
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=REPLACE_WITH_GENERATED_SECRET
AUTH_SECRET=REPLACE_WITH_GENERATED_SECRET
NEXTAUTH_URL=https://smartly.aero
JWT_SECRET=REPLACE_WITH_GENERATED_SECRET

# ---------------------------------------------------------------------------
# Aviation API (Flight tracking)
# ---------------------------------------------------------------------------
AVIATION_API_KEY=your_aviationstack_key

# ---------------------------------------------------------------------------
# AI / LLM
# ---------------------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key

# ---------------------------------------------------------------------------
# WhatsApp Business API
# ---------------------------------------------------------------------------
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# ---------------------------------------------------------------------------
# Payment (CinetPay)
# ---------------------------------------------------------------------------
CINETPAY_API_KEY=
CINETPAY_SITE_ID=

# ---------------------------------------------------------------------------
# Socket.io (WebSocket service)
# ---------------------------------------------------------------------------
WS_PORT=3003
